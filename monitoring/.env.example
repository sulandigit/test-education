# 领课教育监控系统环境变量配置
# 请根据实际情况修改以下配置

# 钉钉机器人配置
# 请替换为你的钉钉机器人 Webhook URL
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_ACCESS_TOKEN

# 钉钉机器人密钥（可选，如果启用了加签验证）
DINGTALK_SECRET=YOUR_SECRET

# 邮件配置
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=alerts@education.roncoo.com
EMAIL_PASSWORD=your_email_password

# 数据存储路径
MONITORING_DATA_PATH=/data/monitoring